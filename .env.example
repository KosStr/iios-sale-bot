# Get this token from @BotFather on Telegram
BOT_TOKEN=123456789:your-telegram-bot-token-here

# Optional: comma-separated Telegram user IDs that receive new order notifications
ADMIN_CHAT_IDS=

# Currency code shown by default (UAH or USD)
CURRENCY=UAH

# --- Store contacts (shown by the «Контакти» button) -------------------------
STORE_NAME=IIOS Store
STORE_PHONE=+380 99 123 45 67
STORE_PHONE2=+380 73 987 65 43
STORE_EMAIL=info@iios.store
STORE_TELEGRAM=@iios_cv
STORE_INSTAGRAM=@iios.store
STORE_WEBSITE=https://iios.store
STORE_HOURS=Пн–Нд, 10:00–20:00

# --- Store location (shown by the «Локація» button) --------------------------
STORE_ADDRESS=м. Чернівці, вул. Головна, 1
STORE_LATITUDE=48.291839
STORE_LONGITUDE=25.935355

# --- Cloudflare R2 image storage (all optional) ------------------------------
# Option A: public bucket / custom domain — simplest. Telegram fetches by URL.
# Example: https://pub-xxxxxxxx.r2.dev  or  https://img.your-domain.com
R2_PUBLIC_BASE_URL=

# Option B: private bucket — the bot pulls image bytes via the S3 API.
# Find the Account ID and create an R2 API token in the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Image object keys default to "<product_id>.jpg" (e.g. iphone-15-pro.jpg).
